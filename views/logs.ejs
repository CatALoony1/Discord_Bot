<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Bot Logs</title>
    <style>
      .log-container {
        background-color: #1e1e1e;
        color: #d4d4d4;
        font-family: 'Consolas', 'Courier New', monospace;
        padding: 15px;
        border-radius: 6px;
        height: 500px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
      }
    </style>
  </head>
  <body>
    <h1>Bot Logs</h1>
    <div class="log-container" id="logBox"><%= logData %></div>
    <script>
      const logBox = document.getElementById('logBox');
      logBox.scrollTop = logBox.scrollHeight;
    </script>
  </body>
</html>
