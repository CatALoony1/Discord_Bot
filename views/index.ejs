<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Bot Dashboard</title>
  </head>
  <body>
    <h1>Willkommen im Control Panel!</h1>
    <% if (message) { %>
    <p><%= message %></p>
    <% } %>
    <br /><br />
    <a
      href="/rechner"
      style="
        padding: 10px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      "
      >Zum Rechner</a
    >
    <a
      href="/kanaele"
      style="
        padding: 10px;
        background-color: #28a745;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      "
      >Kanäle anzeigen</a
    >
    <a
      href="/read-database"
      style="
        padding: 10px;
        background-color: #a12597;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      "
      >Datenbank auslesen</a
    >
    <a
      href="/user-management"
      style="
        padding: 10px;
        background-color: #bd6f16;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      "
      >User Management</a
    >
    <a
      href="/logout"
      style="
        padding: 10px;
        background-color: #d30909;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      "
      >Logout</a
    >
  </body>
</html>
