<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Jobs</title>
  </head>
  <body>
    <h1>Jobs</h1>
    <% if (locals.error) { %>
    <div class="error-box">
      <strong>Fehler:</strong>
      <%= error %>
    </div>
    <% } %>
    <form action="/jobs/all" method="POST" style="display: inline">
      <input type="hidden" name="action" value="start" />
      <button type="submit" style="background-color: green; color: white">
        Alle starten
      </button>
    </form>
    <form action="/jobs/all" method="POST" style="display: inline">
      <input type="hidden" name="action" value="stop" />
      <button type="submit" style="background-color: red; color: white">
        Alle stoppen
      </button>
    </form>
    <% if (alleJobs && alleJobs.length > 0) { %>
    <h2>Gefundene Jobs:</h2>
    <table border="1" cellpadding="5" style="border-collapse: collapse">
      <thead>
        <tr>
          <th>Name</th>
          <th>Status</th>
          <th>Aktion</th>
        </tr>
      </thead>
      <tbody>
        <% alleJobs.forEach(function(job) { %>
        <tr>
          <td><%= job.jobname %></td>
          <% if (job.jobname === 'checkNewAnimals') { %>
          <td style="color: blue">No Running Job</td>
          <% } else if (job.status) { %>
          <td style="color: green">Aktiv</td>
          <% } else { %>
          <td style="color: red">Inaktiv</td>
          <% } %>
          <td>
            <% if (job.jobname !== 'checkNewAnimals') { %>
            <% if (job.status) { %>
            <form action="/jobs/stop" method="POST" style="display: inline">
              <input type="hidden" name="jobname" value="<%= job.jobname %>" />
              <button type="submit" style="background-color: red; color: white">
                Stoppen
              </button>
            </form>
            <% } else { %>
            <form action="/jobs/start" method="POST" style="display: inline">
              <input type="hidden" name="jobname" value="<%= job.jobname %>" />
              <button
                type="submit"
                style="background-color: green; color: white"
              >
                starten
              </button>
            </form>
            <% } %>
            <% } %>
            <% if (job.jobname === 'checkNewAnimals' || job.jobname === 'cronJob_geburtstag' || job.jobname === 'cronJob_quizQuestion' || job.jobname === 'cronJob_quizStats') { %>
            <form action="/jobs/execute" method="POST" style="display: inline">
              <input type="hidden" name="jobname" value="<%= job.jobname %>" />
              <button
                type="submit"
                style="background-color: blue; color: white"
              >
                ausführen
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %>
    <p>Es gibt keine Jobs.</p>
    <% } %>
    <br /><br />
    <a href="/">Zurück zur Startseite</a>
  </body>
</html>
