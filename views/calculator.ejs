<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Rechner - Dashboard</title>
</head>
<body>
    <h1>Ziffern-Rechner</h1>
    
    <form action="/rechner" method="POST">
        <label for="zahl">Bitte eine Zahl eingeben:</label>
        <input type="number" id="zahl" name="eingabeZahl" required>
        
        <!-- Zwei Buttons mit dem gleichen Namen, aber unterschiedlichen Werten -->
        <button type="submit" name="aktion" value="plus">Berechnen (+1)</button>
        <button type="submit" name="aktion" value="minus">Berechnen (-1)</button>
    </form>

    <br>

    <!-- Diese Box wird nur gerendert, wenn das Backend ein 'ergebnis' mitschickt -->
    <% if (typeof ergebnis !== 'undefined') { %>
        <div style="padding: 10px; background-color: #d4edda; border: 1px solid #c3e6cb;">
            Das Ergebnis ist: <strong><%= ergebnis %></strong>
        </div>
    <% } %>

    <br>
    <a href="/">Zurück zur Startseite</a>
</body>
</html>